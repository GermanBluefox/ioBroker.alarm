{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "allowJs": false,
        "checkJs": false,
        "noEmit": false,
        "declaration": true,
        "outDir": "build",
        "sourceMap": true,
        "types": ["@iobroker/types"]
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts"],
    "exclude": ["src/**/*.test.ts"]
}
